# bin/ 配下のラッパースクリプト共通設定。
# bin/phpstan および bin/php-cs-fixer からソースされる。
#
# 環境変数で上書き可能:
#   DOCKER_IMAGE      - 使用する Docker イメージ名
#   DOCKER_CONTAINER_ROOT - コンテナ内プロジェクトルート

# Docker イメージ名 (compose.yml の image: と合わせること)
DOCKER_IMAGE="${DOCKER_IMAGE:-udonarium-axe-backend-app}"

# コンテナ内にマウントするプロジェクトルートのパス
# (Dockerfile の WORKDIR および DocumentRoot と合わせること)
DOCKER_CONTAINER_ROOT="${DOCKER_CONTAINER_ROOT:-/var/www/html}"
