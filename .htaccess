# 機密・開発用ファイルへの直接アクセスを遮断

<FilesMatch "^(\..+|Dockerfile(\..+)?|docker-compose(\..+)?|compose\.yml|composer\.(json|lock)|package(-lock)?\.json|.+\.lock|phpunit\.xml|phpstan\.neon)$">
Require all denied
</FilesMatch>

RewriteEngine On

# vendor/ 等のディレクトリへのアクセスを遮断（実在ファイルチェックより前に処理）

RewriteRule ^(vendor|tests|bin|docs|coverage-report|node_modules)(/|$) - [F,L]

# 実在するファイルへのリクエストはそのまま通す（静的ファイル等）

RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# それ以外は index.php にルーティング

RewriteRule ^ index.php [QSA,L]
