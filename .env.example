# .env ファイルの配置場所について:
# セキュリティのため、.env はドキュメントルートの一つ上のディレクトリに置くことを推奨します。
# 例: ドキュメントルートが /home/user/public_html/backend/ なら
#     /home/user/.env に配置してください。
# ドキュメントルート内に置く場合は .htaccess による保護が有効であることを確認してください。
#
# Apache の環境変数 ENV_PATH で任意のパスを直接指定することもできます。
# 例 (.htaccess): SetEnv ENV_PATH /home/user/secret/.env

# SkyWay アプリケーション ID
SKYWAY_APP_ID=your_skyway_app_id_here

# SkyWay シークレットキー
# 注意: # を含む値はダブルクォートで囲むこと。囲まないと # 以降がコメントとして切り捨てられる。
# 例: SKYWAY_SECRET="abc#def"
SKYWAY_SECRET=your_skyway_secret_here

# ロビーチャンネルの最大数（省略時: 3）
SKYWAY_UDONARIUM_LOBBY_SIZE=3

# アクセスを許可するオリジン（カンマ区切りで複数指定可・ワイルドカード * も可）
# 注意: * を指定するとすべてのオリジンを許可する。本番環境では必ず具体的な URL を指定すること。
ACCESS_CONTROL_ALLOW_ORIGIN=https://example.com,https://www.example.com
