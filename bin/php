#!/bin/bash
# PHP を Docker コンテナ内で実行するラッパースクリプト。
# VS Code の phpunit 拡張機能 (recca0120.vscode-phpunit) から
# このスクリプトが呼び出される。
#
# 使用方法:
#   bin/php [php の引数...]
#
# 引数はそのまま php に渡される。
# コンテナ内のパスとホストのパスを対応させるため
# プロジェクトルートをマウントポイントとして固定する。

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=bin/.config
. "$(dirname "$0")/.config"

# VS Code 拡張はホスト側絶対パスを引数で渡す。
# コンテナ内には同じパスが存在しないため、すべての引数内の
# ホスト側プロジェクトルートをコンテナ内マウントポイントに置換する。
args=()
for arg in "$@"; do
    args+=("${arg//${PROJECT_ROOT}/${DOCKER_CONTAINER_ROOT}}")
done

exec docker run --rm \
  -v "${PROJECT_ROOT}:${DOCKER_CONTAINER_ROOT}" \
  -w "${DOCKER_CONTAINER_ROOT}" \
  "${DOCKER_IMAGE}" \
  php "${args[@]}"
